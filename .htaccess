DirectoryIndex index.html
ErrorDocument 404 /404.html

RewriteEngine On

# 1) Remove index.html from any URL ( /foo/index.html -> /foo/ )
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L]

# 2) Remove .html from any URL ( /about.html -> /about )
RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# 3) Internally serve the .html file when someone requests /about
#    (only if /about is not an existing file/dir and /about.html exists)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
